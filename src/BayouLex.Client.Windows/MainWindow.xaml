<Window x:Class="BayouLex.Client.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BayouLex"
        Icon="Assets/bayoulex-brand.png"
        Width="1380"
        Height="880"
        MinWidth="1080"
        MinHeight="720"
        Background="#EEF1EC"
        Loaded="Window_Loaded">
  <Window.Resources>
    <SolidColorBrush x:Key="InkBrush" Color="#111C18" />
    <SolidColorBrush x:Key="MutedBrush" Color="#4F5E58" />
    <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="LineBrush" Color="#6E7D75" />
    <SolidColorBrush x:Key="SoftLineBrush" Color="#C7D0CA" />
    <SolidColorBrush x:Key="AccentBrush" Color="#0C5C4D" />
    <SolidColorBrush x:Key="DeepAccentBrush" Color="#17372F" />
    <SolidColorBrush x:Key="SoftAccentBrush" Color="#DDEBE5" />
    <SolidColorBrush x:Key="GoldBrush" Color="#B68A3C" />
    <SolidColorBrush x:Key="PaperBrush" Color="#FAFBF8" />

    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
      <Setter Property="FontFamily" Value="Segoe UI" />
    </Style>

    <Style TargetType="Button">
      <Setter Property="Height" Value="38" />
      <Setter Property="Padding" Value="16,0" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
      <Setter Property="BorderThickness" Value="2" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Background" Value="{StaticResource AccentBrush}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
    </Style>

    <Style TargetType="TextBox">
      <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
      <Setter Property="BorderThickness" Value="2" />
      <Setter Property="Background" Value="White" />
      <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
      <Setter Property="Padding" Value="12,6" />
      <Setter Property="FontFamily" Value="Segoe UI" />
    </Style>

    <Style TargetType="ComboBox">
      <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
      <Setter Property="BorderThickness" Value="2" />
      <Setter Property="Background" Value="White" />
      <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
      <Setter Property="FontFamily" Value="Segoe UI" />
    </Style>

    <Style TargetType="ListView">
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="{StaticResource SoftLineBrush}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="FontFamily" Value="Segoe UI" />
    </Style>

    <Style TargetType="ListViewItem">
      <Setter Property="Padding" Value="6,4" />
      <Setter Property="BorderBrush" Value="#E3E8E4" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
      <ColumnDefinition x:Name="SettingsColumn" Width="0" />
    </Grid.ColumnDefinitions>

    <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Background="{StaticResource DeepAccentBrush}" BorderBrush="#0A241E" BorderThickness="0,0,0,3">
      <DockPanel Margin="20,16">
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
          <Border Background="#F4F8F5" BorderBrush="{StaticResource GoldBrush}" BorderThickness="2" Padding="12,6" Margin="0,0,12,0">
            <TextBlock x:Name="ModeTextBlock" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Text="API mode" />
          </Border>
          <Button x:Name="SettingsButton" Content="Settings" Width="108" Background="#FFFFFF" BorderBrush="{StaticResource GoldBrush}" Click="SettingsButton_Click" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <Border Width="54" Height="54" Background="#FFFFFF" BorderBrush="{StaticResource GoldBrush}" BorderThickness="2" Margin="0,0,14,0">
            <Image Width="44" Height="44" Source="Assets/bayoulex-brand.png" />
          </Border>
          <StackPanel>
            <TextBlock Text="BayouLex" FontSize="28" FontWeight="Bold" Foreground="#FFFFFF" />
            <TextBlock x:Name="DatasetTextBlock" Text="Dataset loading" Foreground="#DDEBE5" FontSize="13" FontWeight="SemiBold" />
          </StackPanel>
        </StackPanel>
      </DockPanel>
    </Border>

    <Border Grid.Row="1" Grid.Column="0" Margin="20,18,20,14" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="2">
      <Grid Margin="14">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <DockPanel Margin="0,0,0,10">
          <TextBlock Text="Search the compendium" FontSize="15" FontWeight="Bold" />
          <TextBlock DockPanel.Dock="Right" Text="API-first legal research" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" />
        </DockPanel>
        <Grid Grid.Row="1">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="120" />
          </Grid.ColumnDefinitions>
          <TextBox x:Name="SearchTextBox"
                   Grid.Column="0"
                   Height="46"
                   FontSize="16"
                   VerticalContentAlignment="Center"
                   TextChanged="SearchTextBox_TextChanged"
                   ToolTip="Search BayouLex" />
          <ComboBox x:Name="CategoryComboBox"
                    Grid.Column="1"
                    Margin="12,0,0,0"
                    Height="46"
                    VerticalContentAlignment="Center"
                    SelectionChanged="CategoryComboBox_SelectionChanged" />
          <ComboBox x:Name="LimitComboBox"
                    Grid.Column="2"
                    Margin="12,0,0,0"
                    Height="46"
                    VerticalContentAlignment="Center"
                    SelectionChanged="LimitComboBox_SelectionChanged" />
        </Grid>
      </Grid>
    </Border>

    <Grid Grid.Row="2" Grid.Column="0" Margin="20,0,20,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="460" MinWidth="340" />
        <ColumnDefinition Width="12" />
        <ColumnDefinition Width="*" MinWidth="420" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="2">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <Border Background="{StaticResource DeepAccentBrush}" BorderBrush="{StaticResource GoldBrush}" BorderThickness="0,0,0,3">
            <DockPanel Margin="14,11">
              <TextBlock Text="Results" FontSize="15" FontWeight="Bold" Foreground="#FFFFFF" />
              <Border DockPanel.Dock="Right" Background="#FFFFFF" BorderBrush="{StaticResource GoldBrush}" BorderThickness="1" Padding="8,2">
                <TextBlock x:Name="ResultCountTextBlock" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" />
              </Border>
            </DockPanel>
          </Border>
          <ListView x:Name="ResultsListView"
                    Grid.Row="1"
                    BorderThickness="0"
                    ItemsSource="{Binding Results}"
                    SelectionChanged="ResultsListView_SelectionChanged"
                    VirtualizingPanel.IsVirtualizing="True"
                    VirtualizingPanel.VirtualizationMode="Recycling"
                    ScrollViewer.IsDeferredScrollingEnabled="True">
            <ListView.View>
              <GridView>
                <GridViewColumn Header="Citation" Width="120" DisplayMemberBinding="{Binding Citation}" />
                <GridViewColumn Header="Title" Width="230" DisplayMemberBinding="{Binding Title}" />
                <GridViewColumn Header="Source" Width="170" DisplayMemberBinding="{Binding Category}" />
              </GridView>
            </ListView.View>
          </ListView>
        </Grid>
      </Border>

      <GridSplitter Grid.Column="1" Width="12" HorizontalAlignment="Stretch" Background="#EEF1EC" />

      <Border Grid.Column="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="2">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <Border Background="#F8FAF7" BorderBrush="{StaticResource GoldBrush}" BorderThickness="0,0,0,3">
            <Grid Margin="18,14">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Border Background="{StaticResource GoldBrush}" />
              <TextBlock x:Name="DetailTitleTextBlock" Grid.Column="1" FontSize="20" FontWeight="Bold" TextWrapping="Wrap" Margin="12,0,0,0" />
            </Grid>
          </Border>
          <TextBlock x:Name="DetailUrlTextBox" Grid.Row="1" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="18,12,18,10" FontWeight="SemiBold" />
          <TextBox x:Name="DetailTextBox"
                   Grid.Row="2"
                   IsReadOnly="True"
                   BorderBrush="{StaticResource SoftLineBrush}"
                   BorderThickness="1"
                   Margin="18,0,18,18"
                   Background="{StaticResource PaperBrush}"
                   FontFamily="Consolas"
                   FontSize="14"
                   TextWrapping="Wrap"
                   AcceptsReturn="True"
                   VerticalScrollBarVisibility="Auto"
                   HorizontalScrollBarVisibility="Disabled" />
        </Grid>
      </Border>
    </Grid>

    <Border Grid.Row="3" Grid.Column="0" Margin="20,12,20,18" Background="#FFFFFF" BorderBrush="{StaticResource SoftLineBrush}" BorderThickness="1">
      <DockPanel Margin="12,8">
        <ProgressBar x:Name="ProgressBar" DockPanel.Dock="Right" Width="260" Height="18" Minimum="0" Maximum="100" Visibility="Collapsed" />
        <TextBlock x:Name="StatusTextBlock" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" />
      </DockPanel>
    </Border>

    <Border x:Name="SettingsPanel"
            Grid.Row="1"
            Grid.RowSpan="3"
            Grid.Column="1"
            Background="#FFFFFF"
            BorderBrush="{StaticResource DeepAccentBrush}"
            BorderThickness="3,0,0,0"
            Visibility="Collapsed">
      <Grid Margin="20">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="{StaticResource DeepAccentBrush}" BorderBrush="{StaticResource GoldBrush}" BorderThickness="0,0,0,3" Margin="-20,-20,-20,18">
          <DockPanel Margin="20,16">
            <Button DockPanel.Dock="Right" x:Name="CloseSettingsButton" Content="Close" Width="88" Background="#FFFFFF" BorderBrush="{StaticResource GoldBrush}" Click="CloseSettingsButton_Click" />
            <TextBlock Text="Settings" FontSize="22" FontWeight="Bold" Foreground="#FFFFFF" VerticalAlignment="Center" />
          </DockPanel>
        </Border>

        <Border Grid.Row="1" BorderBrush="{StaticResource LineBrush}" BorderThickness="2" Background="#F8FAF7" Padding="14" Margin="0,0,0,18">
          <StackPanel>
            <TextBlock Text="Connection" FontWeight="Bold" FontSize="15" Margin="0,0,0,10" />
            <TextBlock Text="API base URL" Foreground="{StaticResource MutedBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,5" />
            <TextBox x:Name="ApiBaseTextBox" Height="40" Text="https://api.ladf.us/bayoulex/v1/" />
            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
              <Button x:Name="RefreshButton" Content="Connect" Width="108" Style="{StaticResource PrimaryButton}" Click="RefreshButton_Click" />
              <Button x:Name="ResetLocalApiButton" Content="Local API" Width="108" Margin="10,0,0,0" Click="ResetLocalApiButton_Click" />
            </StackPanel>
          </StackPanel>
        </Border>

        <Border Grid.Row="2" BorderBrush="{StaticResource LineBrush}" BorderThickness="2" Background="#F8FAF7" Padding="14">
          <StackPanel>
            <TextBlock Text="Offline Data" FontWeight="Bold" FontSize="15" Margin="0,0,0,10" />
            <Button x:Name="OfflineButton" Content="Download Data for Offline" Height="42" Margin="0,0,0,10" Style="{StaticResource PrimaryButton}" Click="OfflineButton_Click" />
            <Button x:Name="UseOfflineButton" Content="Use Offline Data" Height="42" Click="UseOfflineButton_Click" />
          </StackPanel>
        </Border>
      </Grid>
    </Border>
  </Grid>
</Window>

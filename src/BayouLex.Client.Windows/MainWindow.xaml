<Window x:Class="BayouLex.Client.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BayouLex"
        Icon="Assets/bayoulex-brand.png"
        Width="1380"
        Height="880"
        MinWidth="1080"
        MinHeight="720"
        Background="#F5F3EE"
        Loaded="Window_Loaded">
  <Window.Resources>
    <SolidColorBrush x:Key="InkBrush" Color="#17231F" />
    <SolidColorBrush x:Key="MutedBrush" Color="#63706B" />
    <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="LineBrush" Color="#D9DED7" />
    <SolidColorBrush x:Key="AccentBrush" Color="#0C5C4D" />
    <SolidColorBrush x:Key="SoftAccentBrush" Color="#E6F0EC" />
    <SolidColorBrush x:Key="GoldBrush" Color="#B68A3C" />

    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
      <Setter Property="FontFamily" Value="Segoe UI" />
    </Style>

    <Style TargetType="Button">
      <Setter Property="Height" Value="34" />
      <Setter Property="Padding" Value="14,0" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Background" Value="{StaticResource AccentBrush}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
    </Style>

    <Style TargetType="TextBox">
      <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="White" />
      <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
      <Setter Property="Padding" Value="10,5" />
      <Setter Property="FontFamily" Value="Segoe UI" />
    </Style>

    <Style TargetType="ComboBox">
      <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="White" />
      <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
      <Setter Property="FontFamily" Value="Segoe UI" />
    </Style>

    <Style TargetType="ListView">
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontFamily" Value="Segoe UI" />
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
      <ColumnDefinition x:Name="SettingsColumn" Width="0" />
    </Grid.ColumnDefinitions>

    <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Background="#FFFFFF" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1">
      <DockPanel Margin="18,14">
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
          <Border Background="{StaticResource SoftAccentBrush}" BorderBrush="#C9DED4" BorderThickness="1" Padding="10,5" Margin="0,0,10,0">
            <TextBlock x:Name="ModeTextBlock" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Text="API mode" />
          </Border>
          <Button x:Name="SettingsButton" Content="Settings" Width="96" Click="SettingsButton_Click" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <Image Width="42" Height="42" Source="Assets/bayoulex-brand.png" Margin="0,0,12,0" />
          <StackPanel>
            <TextBlock Text="BayouLex" FontSize="24" FontWeight="SemiBold" />
            <TextBlock x:Name="DatasetTextBlock" Text="Dataset loading" Foreground="{StaticResource MutedBrush}" FontSize="12" />
          </StackPanel>
        </StackPanel>
      </DockPanel>
    </Border>

    <Grid Grid.Row="1" Grid.Column="0" Margin="18,16,18,12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="260" />
        <ColumnDefinition Width="110" />
      </Grid.ColumnDefinitions>
      <TextBox x:Name="SearchTextBox"
               Grid.Column="0"
               Height="40"
               FontSize="15"
               VerticalContentAlignment="Center"
               TextChanged="SearchTextBox_TextChanged"
               ToolTip="Search BayouLex" />
      <ComboBox x:Name="CategoryComboBox"
                Grid.Column="1"
                Margin="10,0,0,0"
                Height="40"
                VerticalContentAlignment="Center"
                SelectionChanged="CategoryComboBox_SelectionChanged" />
      <ComboBox x:Name="LimitComboBox"
                Grid.Column="2"
                Margin="10,0,0,0"
                Height="40"
                VerticalContentAlignment="Center"
                SelectionChanged="LimitComboBox_SelectionChanged" />
    </Grid>

    <Grid Grid.Row="2" Grid.Column="0" Margin="18,0,18,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="420" MinWidth="320" />
        <ColumnDefinition Width="10" />
        <ColumnDefinition Width="*" MinWidth="420" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <DockPanel Margin="14,12">
            <TextBlock Text="Results" FontSize="15" FontWeight="SemiBold" />
            <TextBlock x:Name="ResultCountTextBlock" DockPanel.Dock="Right" Foreground="{StaticResource MutedBrush}" />
          </DockPanel>
          <ListView x:Name="ResultsListView"
                    Grid.Row="1"
                    BorderThickness="0"
                    ItemsSource="{Binding Results}"
                    SelectionChanged="ResultsListView_SelectionChanged"
                    VirtualizingPanel.IsVirtualizing="True"
                    VirtualizingPanel.VirtualizationMode="Recycling"
                    ScrollViewer.IsDeferredScrollingEnabled="True">
            <ListView.View>
              <GridView>
                <GridViewColumn Header="Citation" Width="110" DisplayMemberBinding="{Binding Citation}" />
                <GridViewColumn Header="Title" Width="210" DisplayMemberBinding="{Binding Title}" />
                <GridViewColumn Header="Source" Width="150" DisplayMemberBinding="{Binding Category}" />
              </GridView>
            </ListView.View>
          </ListView>
        </Grid>
      </Border>

      <GridSplitter Grid.Column="1" Width="10" HorizontalAlignment="Stretch" Background="#F5F3EE" />

      <Border Grid.Column="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1">
        <Grid Margin="18">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <TextBlock x:Name="DetailTitleTextBlock" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,8" />
          <TextBlock x:Name="DetailUrlTextBox" Grid.Row="1" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,0,0,12" />
          <TextBox x:Name="DetailTextBox"
                   Grid.Row="2"
                   IsReadOnly="True"
                   BorderThickness="0"
                   Background="#FBFCFA"
                   FontFamily="Consolas"
                   FontSize="13"
                   TextWrapping="Wrap"
                   AcceptsReturn="True"
                   VerticalScrollBarVisibility="Auto"
                   HorizontalScrollBarVisibility="Disabled" />
        </Grid>
      </Border>
    </Grid>

    <DockPanel Grid.Row="3" Grid.Column="0" Margin="18,12,18,16">
      <ProgressBar x:Name="ProgressBar" DockPanel.Dock="Right" Width="260" Height="18" Minimum="0" Maximum="100" Visibility="Collapsed" />
      <TextBlock x:Name="StatusTextBlock" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" />
    </DockPanel>

    <Border x:Name="SettingsPanel"
            Grid.Row="1"
            Grid.RowSpan="3"
            Grid.Column="1"
            Background="#FFFFFF"
            BorderBrush="{StaticResource LineBrush}"
            BorderThickness="1,0,0,0"
            Visibility="Collapsed">
      <Grid Margin="18">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,18">
          <Button DockPanel.Dock="Right" x:Name="CloseSettingsButton" Content="Close" Width="82" Click="CloseSettingsButton_Click" />
          <TextBlock Text="Settings" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
        </DockPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,22">
          <TextBlock Text="Connection" FontWeight="SemiBold" Margin="0,0,0,8" />
          <TextBlock Text="API base URL" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,4" />
          <TextBox x:Name="ApiBaseTextBox" Height="36" Text="https://api.ladf.us/bayoulex/v1/" />
          <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
            <Button x:Name="RefreshButton" Content="Connect" Width="96" Style="{StaticResource PrimaryButton}" Click="RefreshButton_Click" />
            <Button x:Name="ResetLocalApiButton" Content="Local API" Width="96" Margin="8,0,0,0" Click="ResetLocalApiButton_Click" />
          </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="2">
          <TextBlock Text="Offline Data" FontWeight="SemiBold" Margin="0,0,0,8" />
          <Button x:Name="OfflineButton" Content="Download Data for Offline" Height="38" Margin="0,0,0,8" Style="{StaticResource PrimaryButton}" Click="OfflineButton_Click" />
          <Button x:Name="UseOfflineButton" Content="Use Offline Data" Height="38" Click="UseOfflineButton_Click" />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
